<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.previewmd.updater</string>
    <key>ProgramArguments</key>
    <array>
        <string>/Applications/PreviewMD.app/Contents/Resources/check-update.sh</string>
    </array>
    <key>StartInterval</key>
    <integer>300</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/previewmd-updater.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/previewmd-updater.log</string>
</dict>
</plist>
